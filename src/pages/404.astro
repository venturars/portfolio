---
/**
 * Custom 404 — redirects to index instead of showing not found page.
 */
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="refresh" content="0;url=/" />
    <title>Redirecting...</title>
    <link rel="canonical" href="/" />
  </head>
  <body>
  </body>
</html>
